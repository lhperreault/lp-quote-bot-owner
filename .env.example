# Copy to .env locally; in Vercel, set these in Project Settings -> Environment Variables.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
AIRTABLE_PAT=pat...
AIRTABLE_BASE_ID=appqep8mBMzhS6lFt
AIRTABLE_TABLE_ID=tblJzQYXCTNhGhtku
LP_SHARED_SECRET=pick-a-long-random-string

# ─── Twilio (SMS + voice) ────────────────────────────────────────────────
# From Twilio Console -> Account Info
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# Your business Twilio number in E.164 format, e.g. +18449040754
TWILIO_BUSINESS_NUMBER=+18449040754
# Luke's personal cell — where draft SMS notifications go + the 10s ring target
LUKE_PERSONAL_NUMBER=+12679128285

# ─── Business hours (Luke's local TZ) ────────────────────────────────────
# Calls during hours -> ring Luke's phone; outside hours -> straight to AI voicemail
BUSINESS_TZ=America/New_York
BUSINESS_HOURS_START=8
BUSINESS_HOURS_END=18
# Mon=0, Tue=1, ..., Sun=6. Default Mon-Sat:
BUSINESS_DAYS=0,1,2,3,4,5
CALL_FORWARD_RING_SECONDS=10

# ─── Public URL for this deployment ──────────────────────────────────────
# Used inside Twilio TwiML so callbacks (recording, transcription) can hit us.
PUBLIC_BASE_URL=https://lp-quote-server.vercel.app

# ─── SMS approval (Phase 1) ──────────────────────────────────────────────
# HMAC secret for signed approval URLs. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
APPROVAL_TOKEN_SECRET=pick-a-fresh-random-hex
# How long an approval URL stays valid (seconds). Default 86400 = 24h.
APPROVAL_TOKEN_TTL_SECONDS=86400
# Set to false only for local testing. In prod, leave unset (defaults to true).
TWILIO_WEBHOOK_VALIDATE=true
# Airtable table name or ID for the Edit Log table. Default "Edit Log".
EDIT_LOG_TABLE=Edit Log

# ─── Notion rules fetch (Phase 1) ────────────────────────────────────────
# Internal integration token from https://www.notion.so/profile/integrations.
# Share each rules page with the integration before it can read them.
NOTION_API_KEY=secret_...
# Comma-separated Notion page IDs: Pricing, Voice Guide, Objections, FAQ, Service Area, Scheduling.
NOTION_RULES_PAGE_IDS=
# How long fetched rules are cached per page (seconds). Default 300 = 5 min.
NOTION_RULES_TTL_SECONDS=300
